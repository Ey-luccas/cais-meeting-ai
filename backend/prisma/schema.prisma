generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextIndex"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum OrganizationRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

enum ProjectRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

enum MeetingStatus {
  PENDING
  UPLOADED
  TRANSCRIBING
  TRANSCRIBED
  PROCESSING_AI
  COMPLETED
  FAILED
}

enum ObservationType {
  NOTE
  TASK
  QUESTION
  IMPORTANT
  DECISION
}

enum CardSourceType {
  MANUAL
  AI
}

enum CardPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum CardActivityType {
  CARD_CREATED
  CARD_UPDATED
  CARD_MOVED
  CARD_DELETED
  ASSIGNEE_ADDED
  ASSIGNEE_REMOVED
  DUE_DATE_UPDATED
  PRIORITY_UPDATED
  CHECKLIST_CREATED
  CHECKLIST_UPDATED
  CHECKLIST_REMOVED
  CHECKLIST_ITEM_CREATED
  CHECKLIST_ITEM_UPDATED
  CHECKLIST_ITEM_TOGGLED
  CHECKLIST_ITEM_REMOVED
  COMMENT_ADDED
  LINK_ADDED
  LINK_UPDATED
  LINK_REMOVED
  ATTACHMENT_ADDED
  ATTACHMENT_REMOVED
  LABEL_CREATED
  LABEL_UPDATED
  LABEL_REMOVED
}

enum AiSearchSourceType {
  PROJECT
  MEETING
  TRANSCRIPT
  MEETING_NOTE
  DECISION
  TASK
  CARD
  CARD_COMMENT
  FILE
  LIBRARY_ITEM
}

enum AiSearchScope {
  ORGANIZATION
  PROJECT
}

enum AiSearchThreadStatus {
  ACTIVE
  ARCHIVED
  DELETED
}

enum AiSearchMessageRole {
  USER
  ASSISTANT
}

enum NotificationType {
  CARD_CREATED
  CARD_ASSIGNED
  CARD_DUE_DATE_SET
  CARD_DUE_SOON
  CARD_OVERDUE
  CARD_COMMENTED
  CARD_MOVED
  MEETING_CREATED
  MEETING_TRANSCRIPTION_READY
  MEETING_NOTES_READY
  FILE_UPLOADED
  PROJECT_MEMBER_ADDED
  SYSTEM
}

enum NotificationChannel {
  IN_APP
  EMAIL
  BOTH
}

enum LibraryItemType {
  DOCUMENT
  FILE
}

enum LibraryItemOrigin {
  MANUAL
  AI
  MEETING
  UPLOAD
}

enum LibraryItemStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum LibraryDocumentType {
  MEETING_MINUTES
  SCOPE
  REQUIREMENTS
  PLANNING
  PROPOSAL
  TECHNICAL
  MANUAL
  DECISION_RECORD
  ACTION_PLAN
  OTHER
}

model Organization {
  id              String               @id @default(uuid())
  name            String
  slug            String               @unique
  email           String
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  members         OrganizationMember[]
  projects        Project[]
  notifications   Notification[]
  aiSearchChunks  AiSearchChunk[]
  aiSearchThreads AiSearchThread[]
}

model User {
  id                      String               @id @default(uuid())
  name                    String
  email                   String               @unique
  passwordHash            String
  avatarUrl               String?
  phone                   String?
  createdAt               DateTime             @default(now())
  updatedAt               DateTime             @updatedAt
  organizationMemberships OrganizationMember[]
  projectMemberships      ProjectMember[]
  createdMeetings         Meeting[]            @relation("MeetingCreator")
  meetingObservations     MeetingObservation[] @relation("MeetingObservationAuthor")
  uploadedProjectFiles    ProjectFile[]        @relation("ProjectFileUploader")
  createdCards            Card[]               @relation("CardCreator")
  cardAssignments         CardAssignee[]
  cardComments            CardComment[]        @relation("CardCommentAuthor")
  uploadedCardAttachments CardAttachment[]     @relation("CardAttachmentUploader")
  cardActivities          CardActivity[]       @relation("CardActivityActor")
  notifications           Notification[]       @relation("NotificationRecipient")
  createdLibraryItems     LibraryItem[]        @relation("LibraryItemCreator")
  updatedLibraryItems     LibraryItem[]        @relation("LibraryItemUpdater")
  libraryItemVersions     LibraryItemVersion[] @relation("LibraryItemVersionAuthor")
  aiSearchThreads         AiSearchThread[]
}

model OrganizationMember {
  id             String           @id @default(uuid())
  organizationId String
  userId         String
  role           OrganizationRole @default(MEMBER)
  createdAt      DateTime         @default(now())
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@index([organizationId])
  @@index([userId])
}

model Project {
  id              String           @id @default(uuid())
  organizationId  String
  name            String
  description     String?          @db.Text
  color           String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  organization    Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  members         ProjectMember[]
  meetings        Meeting[]
  files           ProjectFile[]
  board           Board?
  cards           Card[]
  notifications   Notification[]
  labels          CardLabel[]
  libraryFolders  LibraryFolder[]
  libraryItems    LibraryItem[]
  libraryTags     LibraryTag[]
  aiSearchChunks  AiSearchChunk[]
  aiSearchThreads AiSearchThread[]

  @@index([organizationId])
}

model ProjectMember {
  id        String      @id @default(uuid())
  projectId String
  userId    String
  role      ProjectRole @default(MEMBER)
  createdAt DateTime    @default(now())
  project   Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@index([projectId])
  @@index([userId])
}

model Meeting {
  id              String               @id @default(uuid())
  projectId       String
  title           String
  description     String?              @db.Text
  audioPath       String?
  durationSeconds Int?
  status          MeetingStatus        @default(PENDING)
  createdByUserId String
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  project         Project              @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdByUser   User                 @relation("MeetingCreator", fields: [createdByUserId], references: [id], onDelete: Restrict)
  transcript      Transcript?
  note            MeetingNote?
  observations    MeetingObservation[]
  cards           Card[]
  libraryItems    LibraryItem[]

  @@index([projectId, createdAt])
  @@index([createdByUserId])
  @@index([status])
}

model Transcript {
  id        String   @id @default(uuid())
  meetingId String   @unique
  fullText  String   @db.LongText
  language  String?
  rawJson   Json?
  createdAt DateTime @default(now())
  meeting   Meeting  @relation(fields: [meetingId], references: [id], onDelete: Cascade)
}

model MeetingNote {
  id               String   @id @default(uuid())
  meetingId        String   @unique
  summary          String   @db.LongText
  topicsJson       Json?
  decisionsJson    Json?
  actionItemsJson  Json?
  pendingItemsJson Json?
  commentsJson     Json?
  reportJson       Json?
  createdAt        DateTime @default(now())
  meeting          Meeting  @relation(fields: [meetingId], references: [id], onDelete: Cascade)
}

model MeetingObservation {
  id               String          @id @default(uuid())
  meetingId        String
  authorUserId     String
  timestampSeconds Int
  type             ObservationType
  content          String          @db.Text
  createdAt        DateTime        @default(now())
  meeting          Meeting         @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  authorUser       User            @relation("MeetingObservationAuthor", fields: [authorUserId], references: [id], onDelete: Restrict)

  @@index([meetingId, timestampSeconds])
  @@index([authorUserId])
}

model ProjectFile {
  id               String           @id @default(uuid())
  projectId        String
  uploadedByUserId String
  name             String
  description      String?          @db.VarChar(280)
  filePath         String
  mimeType         String?
  sizeBytes        Int?
  createdAt        DateTime         @default(now())
  project          Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  uploadedByUser   User             @relation("ProjectFileUploader", fields: [uploadedByUserId], references: [id], onDelete: Restrict)
  cardAttachments  CardAttachment[]
  libraryItems     LibraryItem[]

  @@index([projectId, createdAt])
  @@index([uploadedByUserId])
}

model LibraryFolder {
  id        String          @id @default(uuid())
  projectId String
  name      String          @db.VarChar(140)
  parentId  String?
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  project   Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  parent    LibraryFolder?  @relation("LibraryFolderTree", fields: [parentId], references: [id], onDelete: SetNull)
  children  LibraryFolder[] @relation("LibraryFolderTree")
  items     LibraryItem[]

  @@index([projectId, parentId, name])
  @@index([parentId])
}

model LibraryItem {
  id              String               @id @default(uuid())
  projectId       String
  folderId        String?
  meetingId       String?
  projectFileId   String?
  title           String               @db.VarChar(240)
  description     String?              @db.VarChar(1000)
  type            LibraryItemType
  origin          LibraryItemOrigin
  status          LibraryItemStatus    @default(DRAFT)
  documentType    LibraryDocumentType?
  filePath        String?              @db.VarChar(500)
  fileName        String?              @db.VarChar(255)
  mimeType        String?              @db.VarChar(180)
  sizeBytes       Int?
  contentMarkdown String?              @db.LongText
  contentText     String?              @db.LongText
  contentJson     Json?
  createdByUserId String
  updatedByUserId String?
  archivedAt      DateTime?
  deletedAt       DateTime?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  project         Project              @relation(fields: [projectId], references: [id], onDelete: Cascade)
  folder          LibraryFolder?       @relation(fields: [folderId], references: [id], onDelete: SetNull)
  meeting         Meeting?             @relation(fields: [meetingId], references: [id], onDelete: SetNull)
  projectFile     ProjectFile?         @relation(fields: [projectFileId], references: [id], onDelete: SetNull)
  createdByUser   User                 @relation("LibraryItemCreator", fields: [createdByUserId], references: [id], onDelete: Restrict)
  updatedByUser   User?                @relation("LibraryItemUpdater", fields: [updatedByUserId], references: [id], onDelete: SetNull)
  tags            LibraryItemTag[]
  versions        LibraryItemVersion[]

  @@index([projectId, deletedAt, updatedAt])
  @@index([projectId, type, status, updatedAt])
  @@index([projectId, origin, status, updatedAt])
  @@index([projectId, folderId, updatedAt])
  @@index([meetingId])
  @@index([projectFileId])
  @@index([title])
}

model LibraryTag {
  id        String           @id @default(uuid())
  projectId String
  name      String           @db.VarChar(80)
  color     String           @db.VarChar(20)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  project   Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  items     LibraryItemTag[]

  @@unique([projectId, name])
  @@index([projectId, createdAt])
}

model LibraryItemTag {
  id            String      @id @default(uuid())
  libraryItemId String
  tagId         String
  item          LibraryItem @relation(fields: [libraryItemId], references: [id], onDelete: Cascade)
  tag           LibraryTag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([libraryItemId, tagId])
  @@index([tagId])
}

model LibraryItemVersion {
  id              String      @id @default(uuid())
  libraryItemId   String
  contentMarkdown String?     @db.LongText
  contentText     String?     @db.LongText
  contentJson     Json?
  createdByUserId String
  createdAt       DateTime    @default(now())
  item            LibraryItem @relation(fields: [libraryItemId], references: [id], onDelete: Cascade)
  createdByUser   User        @relation("LibraryItemVersionAuthor", fields: [createdByUserId], references: [id], onDelete: Restrict)

  @@index([libraryItemId, createdAt])
  @@index([createdByUserId])
}

model Notification {
  id             String              @id @default(uuid())
  organizationId String
  userId         String?
  projectId      String?
  title          String              @db.VarChar(180)
  message        String              @db.VarChar(1000)
  type           NotificationType
  channel        NotificationChannel
  targetType     String?             @db.VarChar(120)
  targetId       String?             @db.VarChar(120)
  targetHref     String?             @db.VarChar(500)
  isRead         Boolean             @default(false)
  readAt         DateTime?
  emailSentAt    DateTime?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  organization   Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User?               @relation("NotificationRecipient", fields: [userId], references: [id], onDelete: Cascade)
  project        Project?            @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([organizationId, createdAt])
  @@index([organizationId, userId, isRead, createdAt])
  @@index([projectId, createdAt])
}

model Board {
  id        String        @id @default(uuid())
  projectId String        @unique
  name      String
  createdAt DateTime      @default(now())
  project   Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  columns   BoardColumn[]
}

model BoardColumn {
  id        String   @id @default(uuid())
  boardId   String
  title     String
  position  Int
  createdAt DateTime @default(now())
  board     Board    @relation(fields: [boardId], references: [id], onDelete: Cascade)
  cards     Card[]

  @@unique([boardId, position])
  @@index([boardId])
}

model Card {
  id              String              @id @default(uuid())
  boardColumnId   String
  projectId       String
  meetingId       String?
  position        Int
  title           String
  description     String?             @db.Text
  sourceType      CardSourceType      @default(MANUAL)
  priority        CardPriority?
  dueDate         DateTime?
  createdByUserId String
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  boardColumn     BoardColumn         @relation(fields: [boardColumnId], references: [id], onDelete: Cascade)
  project         Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  meeting         Meeting?            @relation(fields: [meetingId], references: [id], onDelete: SetNull)
  createdByUser   User                @relation("CardCreator", fields: [createdByUserId], references: [id], onDelete: Restrict)
  assignees       CardAssignee[]
  checklists      CardChecklist[]
  comments        CardComment[]
  attachments     CardAttachment[]
  links           CardLink[]
  labels          CardLabelRelation[]
  activities      CardActivity[]

  @@unique([boardColumnId, position])
  @@index([boardColumnId])
  @@index([boardColumnId, position])
  @@index([projectId, boardColumnId])
  @@index([meetingId])
  @@index([createdByUserId])
}

model CardAssignee {
  id        String   @id @default(uuid())
  cardId    String
  userId    String
  createdAt DateTime @default(now())
  card      Card     @relation(fields: [cardId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([cardId, userId])
  @@index([userId])
}

model CardChecklist {
  id        String              @id @default(uuid())
  cardId    String
  title     String
  position  Int
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt
  card      Card                @relation(fields: [cardId], references: [id], onDelete: Cascade)
  items     CardChecklistItem[]

  @@index([cardId, position])
}

model CardChecklistItem {
  id          String        @id @default(uuid())
  checklistId String
  content     String
  isCompleted Boolean       @default(false)
  position    Int
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  checklist   CardChecklist @relation(fields: [checklistId], references: [id], onDelete: Cascade)

  @@index([checklistId, position])
}

model CardComment {
  id           String   @id @default(uuid())
  cardId       String
  authorUserId String
  content      String   @db.Text
  createdAt    DateTime @default(now())
  card         Card     @relation(fields: [cardId], references: [id], onDelete: Cascade)
  authorUser   User     @relation("CardCommentAuthor", fields: [authorUserId], references: [id], onDelete: Restrict)

  @@index([cardId, createdAt])
  @@index([authorUserId])
}

model CardAttachment {
  id               String       @id @default(uuid())
  cardId           String
  uploadedByUserId String
  projectFileId    String?
  name             String
  filePath         String
  mimeType         String?
  sizeBytes        Int?
  createdAt        DateTime     @default(now())
  card             Card         @relation(fields: [cardId], references: [id], onDelete: Cascade)
  uploadedByUser   User         @relation("CardAttachmentUploader", fields: [uploadedByUserId], references: [id], onDelete: Restrict)
  projectFile      ProjectFile? @relation(fields: [projectFileId], references: [id], onDelete: SetNull)

  @@index([cardId])
  @@index([uploadedByUserId])
  @@index([projectFileId])
}

model CardLink {
  id        String   @id @default(uuid())
  cardId    String
  title     String
  url       String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  card      Card     @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@index([cardId])
}

model CardLabel {
  id        String              @id @default(uuid())
  projectId String
  name      String
  color     String
  createdAt DateTime            @default(now())
  project   Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  cards     CardLabelRelation[]

  @@unique([projectId, name])
  @@index([projectId])
}

model CardLabelRelation {
  id      String    @id @default(uuid())
  cardId  String
  labelId String
  card    Card      @relation(fields: [cardId], references: [id], onDelete: Cascade)
  label   CardLabel @relation(fields: [labelId], references: [id], onDelete: Cascade)

  @@unique([cardId, labelId])
  @@index([labelId])
}

model CardActivity {
  id           String           @id @default(uuid())
  cardId       String
  actorUserId  String
  type         CardActivityType
  metadataJson Json?
  createdAt    DateTime         @default(now())
  card         Card             @relation(fields: [cardId], references: [id], onDelete: Cascade)
  actorUser    User             @relation("CardActivityActor", fields: [actorUserId], references: [id], onDelete: Restrict)

  @@index([cardId, createdAt])
  @@index([actorUserId])
}

model AiSearchChunk {
  id             String             @id @default(uuid())
  organizationId String
  projectId      String?
  sourceType     AiSearchSourceType
  sourceId       String
  title          String
  content        String             @db.LongText
  summary        String?            @db.LongText
  href           String
  metadataJson   Json?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  organization   Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project        Project?           @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([organizationId, projectId, updatedAt])
  @@index([organizationId, sourceType, sourceId])
  @@index([projectId, sourceType, updatedAt])
  @@fulltext([title, content])
}

model AiSearchThread {
  id             String               @id @default(uuid())
  organizationId String
  projectId      String?
  userId         String
  title          String
  scope          AiSearchScope
  status         AiSearchThreadStatus @default(ACTIVE)
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  archivedAt     DateTime?
  deletedAt      DateTime?
  organization   Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project        Project?             @relation(fields: [projectId], references: [id], onDelete: SetNull)
  user           User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages       AiSearchMessage[]

  @@index([organizationId, userId, status, updatedAt])
  @@index([organizationId, projectId, status, updatedAt])
}

model AiSearchMessage {
  id         String                  @id @default(uuid())
  threadId   String
  role       AiSearchMessageRole
  content    String                  @db.LongText
  answerJson Json?
  createdAt  DateTime                @default(now())
  thread     AiSearchThread          @relation(fields: [threadId], references: [id], onDelete: Cascade)
  sources    AiSearchMessageSource[]

  @@index([threadId, createdAt])
}

model AiSearchMessageSource {
  id         String             @id @default(uuid())
  messageId  String
  sourceType AiSearchSourceType
  sourceId   String
  title      String
  href       String
  excerpt    String?            @db.LongText
  createdAt  DateTime           @default(now())
  message    AiSearchMessage    @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId, sourceType, sourceId])
}
