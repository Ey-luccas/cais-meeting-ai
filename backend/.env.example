NODE_ENV=production
PORT=3017
DATABASE_URL="mysql://root:root@localhost:3306/cais_meeting_ai"
CORS_ORIGIN="https://teams.caishub.com.br"
FRONTEND_APP_URL="https://teams.caishub.com.br"

UPLOAD_DIR="uploads"
MAX_FILE_SIZE_MB=200

JWT_SECRET="change-this-super-secret-key-with-24-plus-characters"
JWT_EXPIRES_IN="12h"
AUTH_COOKIE_NAME="cais_meeting_ai_auth"
AUTH_COOKIE_MAX_AGE_DAYS=7

TRANSCRIPTION_ENGINE="GROQ"
GROQ_API_KEY=""
GROQ_STT_MODEL="whisper-large-v3"

DEEPSEEK_API_KEY=""
DEEPSEEK_MODEL="deepseek-chat"
DEEPSEEK_BASE_URL="https://api.deepseek.com"

SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="Cais Teams <noreply@seudominio.com>"
