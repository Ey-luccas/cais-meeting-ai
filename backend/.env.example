NODE_ENV=development
PORT=4000
DATABASE_URL="mysql://root:root@localhost:3306/cais_meeting_ai"
CORS_ORIGIN="http://localhost:3000"
UPLOAD_DIR="uploads"
MAX_FILE_SIZE_MB=200
FFMPEG_BIN="ffmpeg"
FFPROBE_BIN="ffprobe"

GROQ_API_KEY=""
GROQ_STT_MODEL="whisper-large-v3"
GROQ_MAX_CHUNK_MB=25
GROQ_CHUNK_RETRY_ATTEMPTS=2
AUDIO_CHUNK_SECONDS=600
AUDIO_MIN_CHUNK_SECONDS=60

DEEPSEEK_API_KEY=""
DEEPSEEK_MODEL="deepseek-chat"
DEEPSEEK_BASE_URL="https://api.deepseek.com"
