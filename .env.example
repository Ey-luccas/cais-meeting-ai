# =========================================
# Frontend
# =========================================
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_MAX_FILE_SIZE_MB=200

# =========================================
# Backend
# =========================================
PORT=4000
NODE_ENV=development

# =========================================
# Database
# =========================================
DATABASE_URL="mysql://root:root@localhost:3306/cais_meeting_ai"

# =========================================
# Groq
# =========================================
GROQ_API_KEY=
GROQ_STT_MODEL=whisper-large-v3
GROQ_MAX_CHUNK_MB=25
GROQ_CHUNK_RETRY_ATTEMPTS=2
AUDIO_CHUNK_SECONDS=600
AUDIO_MIN_CHUNK_SECONDS=60

# =========================================
# FFmpeg
# =========================================
FFMPEG_BIN=ffmpeg
FFPROBE_BIN=ffprobe

# =========================================
# DeepSeek
# =========================================
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com

# =========================================
# Storage
# =========================================
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=200
